# Metro Housekeeping Inventory & Consumables Portal
# Copy this file to .env and fill in your Supabase project details

# Supabase Project URL (found in: Supabase Dashboard > Project Settings > API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon/Public Key (found in: Supabase Dashboard > Project Settings > API)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# App Configuration
VITE_APP_NAME=Metro HK Portal
VITE_APP_VERSION=1.0.0
